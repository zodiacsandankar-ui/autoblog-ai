# =============================================================================
# AutoBlog AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1
APP_NAME=AutoBlog AI API
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/autoblog_ai?schema=public

# ---------------------------------------------------------------------------
# Redis (Bull queues + caching + rate limiting)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# JWT / Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-characters
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-to-another-strong-random-secret
JWT_REFRESH_EXPIRATION=7d

# ---------------------------------------------------------------------------
# OAuth / SSO Providers
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# ---------------------------------------------------------------------------
# AI / LLM Providers
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_ORG_ID=

GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-pro

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ---------------------------------------------------------------------------
# Stripe (Payments / Billing)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# ---------------------------------------------------------------------------
# AWS S3 (File Uploads / Media Storage)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=autoblog-ai-uploads
AWS_S3_ENDPOINT=

# ---------------------------------------------------------------------------
# Meilisearch (Full-text Search)
# ---------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Bull / Queue Configuration
# ---------------------------------------------------------------------------
BULL_QUEUE_PREFIX=autoblog
BULL_DEFAULT_ATTEMPTS=3
BULL_DEFAULT_BACKOFF=5000

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---------------------------------------------------------------------------
# OpenTelemetry (Observability)
# ---------------------------------------------------------------------------
OTEL_SERVICE_NAME=autoblog-ai-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=

# ---------------------------------------------------------------------------
# Prometheus (Metrics)
# ---------------------------------------------------------------------------
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_DEFAULT_LABELS=app=autoblog-ai-api

# ---------------------------------------------------------------------------
# Logging (Winston)
# ---------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Cookie / Session
# ---------------------------------------------------------------------------
COOKIE_SECRET=change-me-to-a-secret-cookie-string
COOKIE_MAX_AGE=604800000

# ---------------------------------------------------------------------------
# Swagger / API Docs
# ---------------------------------------------------------------------------
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ---------------------------------------------------------------------------
# Schedule / Cron (Optional overrides)
# ---------------------------------------------------------------------------
CRON_POST_SCHEDULER=*/5 * * * *
CRON_ANALYTICS_SYNC=0 */6 * * *
CRON_CONTENT_CLEANUP=0 3 * * 0
