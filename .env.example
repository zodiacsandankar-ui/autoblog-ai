# ─────────────────────────────────────────────────────────────
# AutoBlog AI — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL="postgresql://autoblog:autoblog_secret@localhost:5432/autoblog"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AI Provider — DeepSeek (Primary)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# AI Provider — OpenAI (Optional)
OPENAI_API_KEY="sk-your-openai-api-key"

# AI Provider — Anthropic Claude (Optional)
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# AI Provider — Google Gemini (Optional)
GEMINI_API_KEY="your-gemini-api-key"

# CORS
CORS_ORIGINS="http://localhost:3000"

# Search (Meilisearch)
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="change-meili-master-key"

# Storage (MinIO / S3-compatible)
S3_BUCKET="autoblog-assets"
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

# Stripe (Billing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
EMAIL_FROM="noreply@autoblog.ai"

# Sentry (Error Tracking)
SENTRY_DSN=""

# Logging
LOG_LEVEL="debug"
METRICS_ENABLED="true"

# Next.js Web App
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-nextauth-secret-in-production"
